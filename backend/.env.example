MULTILINGUAL_TARGET_LANGUAGE=English
SUPPORTED_DOCUMENT_LANGUAGES=English,Hindi
CORS_ALLOWED_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
